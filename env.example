# ── Authentication (self-hosted, no Supabase) ────────────────────────────────
# Google OAuth Client ID (same value used by the frontend build).
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
# Secret used to sign backend session JWTs. Use a long random string.
JWT_SECRET=change-me-to-a-long-random-secret
# Optional session lifetime (default 12h).
# JWT_EXPIRES_IN=12h
# Who is allowed in — comma-separated emails and/or Google Workspace domains.
ALLOWED_EMAILS=you@example.com,teammate@example.com
ALLOWED_DOMAINS=
# Bypass auth entirely (LOCAL DEV ONLY).
# AUTH_DISABLED=false

# ── Database (self-hosted Postgres) ──────────────────────────────────────────
POSTGRES_USER=faceid
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=faceid
# The backend builds DATABASE_URL from the values above in docker-compose.

# ── Storage / public URL ─────────────────────────────────────────────────────
# Public base URL where the backend (and its /uploads folder) is reachable.
PUBLIC_BASE_URL=https://back.faceid.alertasenlinea.com.ar

# ── NTechLab API Configuration ───────────────────────────────────────────────
NTECH_API_URL=https://videoia.alertasenlinea.com.ar
NTECH_API_KEY=your-ntech-api-key

# ── MQTT Broker credentials (broker no longer allows anonymous access) ───────
MQTT_USERNAME=backend
MQTT_PASSWORD=change-me-strong-password
