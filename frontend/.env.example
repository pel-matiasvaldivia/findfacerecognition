# NOTE: Create React App inlines these at BUILD time, not runtime. For the
# Docker image they are provided as build args from CI (repository Variables).
# This file is only used for local `npm start` / local builds.

# Backend API URL (include the /api suffix)
REACT_APP_API_URL=https://back.faceid.alertasenlinea.com.ar/api

# Google OAuth Client ID (public; used by Google Identity Services).
# Must match GOOGLE_CLIENT_ID on the backend.
REACT_APP_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
